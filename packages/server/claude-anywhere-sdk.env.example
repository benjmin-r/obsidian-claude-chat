# Copy to /home/USER/.config/claude-anywhere-sdk.env and `chmod 600` it.
# Generate a token with e.g.:  openssl rand -hex 32

# Bearer token clients present on `hello` (must match the plugin's setting).
OCC_TOKEN=replace-with-a-long-random-secret

# Bind address: the server's Tailscale IP. NEVER 0.0.0.0 — the server refuses it.
OCC_HOST=100.64.0.1

# Optional overrides (defaults shown):
OCC_PORT=8765
OCC_VAULT_CWD=/home/USER/vaults/VAULT
OCC_MODEL=claude-opus-4-8

# Do NOT set ANTHROPIC_API_KEY here — it would switch the SDK to metered API billing.
